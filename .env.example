# =============================================================================
# AdeHQ — copy to .env.local for dev; mirror the same keys on Vercel (Production + Preview).
# Vercel: Project Settings → Environment Variables. Redeploy after changing server keys.
# =============================================================================

# --- Public (client-safe) ---
NEXT_PUBLIC_SUPABASE_URL=https://psufoswopnknzhxfyvwa.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_WAMHljbrQbfHMruVyMydUg_Kxls2gKY
# Public site origin for auth email links (must match Supabase Auth → URL Configuration)
NEXT_PUBLIC_SITE_URL=https://ade-hq-eight.vercel.app
# Optional override for confirmation redirect (default: /auth/callback)
# NEXT_PUBLIC_AUTH_REDIRECT_PATH=/auth/callback

# Server-only (never expose to the browser). Prefer SUPABASE_SECRET_KEY (sb_secret_…); legacy name still supported.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SILICONFLOW_API_KEY=
# Vercel AI Gateway (server-only) — used when AI_RUNTIME_V2_PROVIDER_PREF=vercel
AI_GATEWAY_API_KEY=
# Optional Gateway model overrides (provider/model-id format, e.g. openai/gpt-4o-mini)
# AI_GATEWAY_MODEL_EFFICIENT=
# AI_GATEWAY_MODEL_BALANCED=
# AI_GATEWAY_MODEL_STRONG=
# AI_GATEWAY_MODEL_LONG_CONTEXT=
# AI_GATEWAY_MODEL_CODING=
# AI_GATEWAY_MODEL_EMBEDDING=
ADEHQ_DEFAULT_PROVIDER=siliconflow
ADEHQ_SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V4-Flash
ADEHQ_SILICONFLOW_CHEAP_MODEL=deepseek-ai/DeepSeek-V3
ADEHQ_SILICONFLOW_CODER_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
ADEHQ_SILICONFLOW_LONG_CONTEXT_MODEL=MiniMaxAI/MiniMax-M2.5
ADEHQ_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# AI Runtime V2 (V19.9.0a+) — default off; no product behavior change until callers migrate
AI_RUNTIME_V2_MODE=off
AI_RUNTIME_V2_PROVIDER_PREF=auto
# Hot-path gate (V19.9.0d-2): direct employee replies use Runtime V2 only when mode=on AND this is true
AI_RUNTIME_V2_EMPLOYEE_DIRECT_EXECUTION=false
# Hot-path gate (V19.9.0d-3): queued orchestration runs use Runtime V2 only when mode=on AND this is true
AI_RUNTIME_V2_EMPLOYEE_QUEUED_EXECUTION=false
# Legacy (normalized to AI_RUNTIME_V2_MODE — do not use in new code):
# AI_RUNTIME_V2_ENABLED=
# AI_RUNTIME_V2_SHADOW_MODE=

# Work Hours shadow metering (V19.9.1a — measurement only, no charging)
AI_WORK_MINUTE_USD=0.01
AI_WORK_HOURS_SHADOW_ENABLED=true
# Soft warnings (V19.9.1d — advisory only, quality-gated, silent when data is poor)
AI_WORK_HOURS_SOFT_WARNINGS_ENABLED=true
AI_WORK_HOURS_WARNING_MIN_LEDGER_ROWS=10
AI_WORK_HOURS_WARNING_MAX_UNMATCHED_RATIO=0.5
AI_WORK_HOURS_WARNING_MAX_MISSING_COST_RATIO=0.4
AI_WORK_HOURS_WARNING_HIGH_HOURS_THRESHOLD=10
# Readiness audit (V19.9.1e — internal only, no enforcement)
AI_WORK_HOURS_READINESS_MIN_LEDGER_ROWS=50
AI_WORK_HOURS_READINESS_MIN_USAGE_ROWS=30
AI_WORK_HOURS_READINESS_MAX_UNMATCHED_RATIO=0.35
AI_WORK_HOURS_READINESS_MAX_MISSING_COST_RATIO=0.25
AI_WORK_HOURS_READINESS_MAX_RATE_VARIANCE=0.25
AI_WORK_HOURS_READINESS_MAX_CONCENTRATION_RATIO=0.8
# Soft-cap simulation (V19.9.1c-final — internal only, no enforcement)
AI_WORK_HOURS_SOFT_CAP_SIMULATION_ENABLED=true
AI_WORK_HOURS_PRE_RUN_ESTIMATES_ENABLED=true
AI_WORK_HOURS_DEFAULT_WEEKLY_SOFT_CAP_MINUTES=600
AI_WORK_HOURS_DEFAULT_EMPLOYEE_SOFT_CAP_MINUTES=240
# Legacy alias still supported by router fallback:
# STANDARD_COST_PER_WORK_MINUTE_USD=0.01

# Local runtime testing only (V19.9.2 — do not use in production):
# AI_RUNTIME_V2_MODE=on
# AI_RUNTIME_V2_PROVIDER_PREF=mock
# or:
# AI_RUNTIME_V2_MODE=on
# AI_RUNTIME_V2_PROVIDER_PREF=vercel
# AI_GATEWAY_API_KEY=...
# Keep hot-path execution flags false until explicitly ready:
# AI_RUNTIME_V2_EMPLOYEE_DIRECT_EXECUTION=false
# AI_RUNTIME_V2_EMPLOYEE_QUEUED_EXECUTION=false

# Browser research (V20.0.0+) — default mock; Tavily search in V20.0.1 (not live browsing)
BROWSER_RESEARCH_PROVIDER=mock
# Live browser (V20.0.2+) — requires AI_RUNTIME_V2_MODE=on + all gates below
# BROWSER_RESEARCH_PROVIDER=browserbase
# BROWSER_RESEARCH_LIVE_ENABLED=true
# BROWSERBASE_API_KEY=
# BROWSER_RESEARCH_EVIDENCE_ENABLED=true
# BROWSER_RESEARCH_MAX_PAGES=3
# BROWSER_RESEARCH_MAX_SECONDS=120
# BROWSERBASE_SESSION_COST_USD=0.05
# TAVILY_API_KEY=
# TAVILY_MAX_RESULTS=5
# TAVILY_SEARCH_COST_USD=0.008

# Search routing (V20.0.5+) — Gateway Search first, Tavily backup, Browserbase for deep browser work only
# AI_SEARCH_PRIMARY_PROVIDER=gateway_perplexity
# AI_SEARCH_BACKUP_PROVIDER=tavily
# AI_BROWSER_RESEARCH_ENABLED=true
# AI_BROWSER_RESEARCH_REQUIRES_EXPLICIT_DEEP_TASK=true
# AI_GATEWAY_SEARCH_COST_USD=0.005
# AI_GATEWAY_SEARCH_WORK_MINUTES=1.5

# Email deliverability: Supabase sends confirmation mail from noreply@mail.app.supabase.io by default.
# For production, configure custom SMTP in Supabase Dashboard → Authentication → SMTP Settings
# (Resend, SendGrid, etc.) so confirmation emails land in the inbox.
MINTLIFY_CLIENT_ID=
MINTLIFY_CLIENT_SECRET=