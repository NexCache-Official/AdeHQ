# AdeHQ — copy to .env.local and fill in secrets. Never commit real keys.

# --- App URL (checkout redirects + webhook host) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=https://app.adehq.com

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# --- Human / hybrid calls (Cloudflare Realtime SFU) ---
ADEHQ_HUMAN_CALLS_V1=0
NEXT_PUBLIC_ADEHQ_HUMAN_CALLS_V1=0
# Post-MVP optimization; keep off until P2P browser/network QA passes:
NEXT_PUBLIC_ADEHQ_P2P_CALLS_V1=0
# Optional dedicated HMAC secret for encrypted P2P signaling. Falls back to the
# server-only Supabase secret key; never expose this to the browser.
CALL_SIGNALING_SECRET=
CLOUDFLARE_REALTIME_APP_ID=
CLOUDFLARE_REALTIME_API_TOKEN=
# Optional direct-P2P / force-relay credentials (separate Cloudflare TURN key):
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_TURN_API_TOKEN=
# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@adehq.com

# --- Realtime AI employee calls ---
ADEHQ_LIVE_CALLS_V1=0
NEXT_PUBLIC_ADEHQ_LIVE_CALLS_V1=0
ADEHQ_LIVE_CALLS_ROLLOUT=off
# batch_utterance (Groq repair path) | live_streaming (xAI captions)
ADEHQ_LIVE_STT_MODE=batch_utterance
ADEHQ_LIVE_STT_GROQ=1
# xai is the only active streaming route. deepgram/moonshine are optional
# provider-neutral shadow declarations; they do not make provider calls.
ADEHQ_LIVE_STT_PROVIDER=xai
ADEHQ_LIVE_STT_SHADOW_PROVIDERS=
ADEHQ_LIVE_TTS_STANDARD_PROVIDER=xai
ADEHQ_LIVE_TTS_XAI_PREMIUM=0
ADEHQ_LIVE_TTS_SILICONFLOW=1
# vercel_ws during migration | cloudflare_worker after worker rollout
ADEHQ_LIVE_CALLS_TRANSPORT=vercel_ws
# Main app URL for readiness probing; keep unset until the worker exists.
ADEHQ_VOICE_WORKER_URL=
# Shared only by the Next.js server and voice worker; random, at least 32 bytes.
ADEHQ_WORKER_TOKEN_SECRET=
# Worker-side callback origin for protected Brain turn/cancel routes.
ADEHQ_BRAIN_API_BASE_URL=
ADEHQ_CALL_BARGE_IN_V1=1
ADEHQ_CALL_SESSION_SECRET=
GROQ_API_KEY=
XAI_API_KEY=
FISH_AUDIO_API_KEY=
FISH_AUDIO_TTS_MODEL=s2.1-pro
FISH_AUDIO_REFERENCE_ID=

# --- PR-18.2D repeatable voice benchmark (optional; never browser-exposed) ---
# Managed candidates are skipped unless their key and any required endpoint/voice
# are configured. Self-hosted candidates are skipped unless an endpoint is set.
XAI_STT_ENDPOINT=
XAI_TTS_ENDPOINT=
DEEPGRAM_API_KEY=
DEEPGRAM_STT_ENDPOINT=
FISH_TTS_ENDPOINT=https://api.fish.audio/v1/tts
CARTESIA_API_KEY=
CARTESIA_TTS_ENDPOINT=https://api.cartesia.ai/tts/bytes
CARTESIA_VOICE_ID=
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_ENDPOINT=
FISH_S2_ENDPOINT=
QWEN3_TTS_ENDPOINT=
COSYVOICE2_ENDPOINT=
KOKORO_ENDPOINT=
MOONSHINE_ENDPOINT=
WHISPER_CPP_ENDPOINT=
FASTER_WHISPER_ENDPOINT=
# Deterministic WAV fixtures matching the checked-in phrase suite:
VOICE_BENCHMARK_AUDIO_EN_US=
VOICE_BENCHMARK_AUDIO_EN_GB=
VOICE_BENCHMARK_AUDIO_ES_ES=
VOICE_BENCHMARK_AUDIO_FR_FR=
VOICE_BENCHMARK_CONCURRENCY=1
VOICE_BENCHMARK_REPETITIONS=1
VOICE_BENCHMARK_PLAYBACK_BUFFER_MS=20
# Set candidate-specific VOICE_BENCHMARK_*_USD_PER_* rates to calculate cost.
# Rates are deliberately not hard-coded because provider prices and endpoint
# amortization assumptions change.

# --- Revolut Merchant (sole billing provider) ---
# Sandbox first; set REVOLUT_ENVIRONMENT=production with live keys to go live.
REVOLUT_ENVIRONMENT=sandbox
REVOLUT_MERCHANT_API_KEY=
REVOLUT_WEBHOOK_SECRET=
# REVOLUT_CURRENCY=USD
# Pinned Merchant API version for subscriptions (required for PR-20F).
REVOLUT_MERCHANT_API_VERSION=2026-04-20
# REVOLUT_API_VERSION=2026-04-20
# REVOLUT_API_BASE_URL=

# Register webhook in Revolut Business → Merchant API → Webhooks:
#   https://<your-host>/api/billing/revolut/webhook
# Events: ORDER_COMPLETED, ORDER_AUTHORISED
